# Map Tracker Web runtime settings
# 推荐：gevent（已安装时），若遇兼容问题可改为 threading
SOCKETIO_ASYNC_MODE=gevent

# 是否允许 Socket.IO 从 polling 升级为 websocket
# gevent/eventlet 场景建议 true；threading 场景建议 false
SOCKETIO_ALLOW_UPGRADES=true

# 可选：压缩优化
COMPRESS_LEVEL=5
COMPRESS_MIN_SIZE=700

# 可选：多 worker 时可限制 OpenCV 线程，避免争抢
# CV2_NUM_THREADS=2
